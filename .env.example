# GoTripza — Environment template (safe to commit)
# Copy to .env.local and fill in your real values
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
NEXT_PUBLIC_GEMINI_API_KEY=

# ── Travelpayouts ─────────────────────────────────────────────────────────────
# This is the SINGLE affiliate tracking backbone for ALL partners.
# Every partner link routes through: tp.media/click?shmarker=MARKER&promo_id=...
#
# Your marker ID — find it at: https://www.travelpayouts.com/dashboard
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=522867
# API token — for Aviasales flight prices & Hotellook hotel prices
TRAVELPAYOUTS_TOKEN=

# ── Travelpayouts Partner Promo IDs ───────────────────────────────────────────
# HOW TO GET YOUR PROMO IDs:
#   1. https://www.travelpayouts.com/programs
#   2. Click the partner you are enrolled in
#   3. Tools → Links → copy the number after "promo_id="
#
# ── Hotels (universal defaults — no change needed) ──────────────────────────
NEXT_PUBLIC_TP_PROMO_BOOKING=4338
NEXT_PUBLIC_TP_PROMO_TRIPCOM=4064

# ── All other partners — fill from your TP dashboard ────────────────────────
# Car Rental
NEXT_PUBLIC_TP_PROMO_DISCOVERCARS=

# Activities & Attractions
NEXT_PUBLIC_TP_PROMO_GYG=
NEXT_PUBLIC_TP_PROMO_KLOOK=
NEXT_PUBLIC_TP_PROMO_KKDAY=
NEXT_PUBLIC_TP_PROMO_GOCITY=

# Cheap Flights
NEXT_PUBLIC_TP_PROMO_KIWI=
NEXT_PUBLIC_TP_PROMO_CHEAPOAIR=

# eSIM / Mobile Data
NEXT_PUBLIC_TP_PROMO_AIRALO=
NEXT_PUBLIC_TP_PROMO_YESIM=

# Travel Insurance
NEXT_PUBLIC_TP_PROMO_VC=
NEXT_PUBLIC_TP_PROMO_EKTA=

# Flight Compensation
NEXT_PUBLIC_TP_PROMO_AIRHELP=

# Train Travel
NEXT_PUBLIC_TP_PROMO_RAILEUROPE=

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_KEY=

# ── Analytics ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Travelpayouts webhook secret ──────────────────────────────────────────────
TP_WEBHOOK_SECRET=

# ── Unsplash ──────────────────────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=
