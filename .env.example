# GoTripza — Environment template (safe to commit)
# Copy to .env.local and fill in your real values
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
NEXT_PUBLIC_GEMINI_API_KEY=

# ── Travelpayouts (Aviasales flights + Hotellook prices) ─────────────────────
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=
TRAVELPAYOUTS_TOKEN=

# ── Hotels ───────────────────────────────────────────────────────────────────
# Booking.com affiliate ID (Partner Hub: https://partnerhelp.booking.com)
# If empty, GoTripza uses Booking.com via Travelpayouts media link (always tracked)
NEXT_PUBLIC_BOOKING_AID=

# Trip.com affiliate ID (https://www.trip.com/affiliate)
NEXT_PUBLIC_TRIPCOM_AID=

# ── Car Rental ────────────────────────────────────────────────────────────────
# DiscoverCars (https://www.discovercars.com/affiliate)
# Default: uses TRAVELPAYOUTS_MARKER if empty
NEXT_PUBLIC_DISCOVERCARS_AID=

# ── Activities & Attractions ──────────────────────────────────────────────────
# GetYourGuide (https://partner.getyourguide.com)
# Default: uses TRAVELPAYOUTS_MARKER if empty
NEXT_PUBLIC_GYG_PARTNER_ID=

# Klook (https://affiliate.klook.com)
NEXT_PUBLIC_KLOOK_AID=

# KKday (https://affiliate.kkday.com)
NEXT_PUBLIC_KKDAY_CID=

# Go City (https://gocity.com/affiliates)
NEXT_PUBLIC_GOCITY_AID=

# ── Cheap Flights ─────────────────────────────────────────────────────────────
# Kiwi.com (https://www.kiwi.com/us/pages/affiliates)
NEXT_PUBLIC_KIWI_AFFILID=

# CheapOair (https://www.cheapoair.com/affiliate)
NEXT_PUBLIC_CHEAPOAIR_AFFID=

# ── eSIM / Mobile Data ────────────────────────────────────────────────────────
# Airalo (https://www.airalo.com/affiliate)
NEXT_PUBLIC_AIRALO_PARTNER=

# Yesim (https://yesim.app/affiliate)
NEXT_PUBLIC_YESIM_REF=

# ── Travel Insurance ──────────────────────────────────────────────────────────
# VisitorsCoverage (https://www.visitorscoverage.com/affiliates)
NEXT_PUBLIC_VC_AGENT=

# EKTA Insurance (https://ekta.insurance/partners)
NEXT_PUBLIC_EKTA_REF=

# ── Flight Compensation ───────────────────────────────────────────────────────
# AirHelp (https://www.airhelp.com/en/affiliate-program)
NEXT_PUBLIC_AIRHELP_PARTNER=

# ── Train Travel ──────────────────────────────────────────────────────────────
# Rail Europe (https://www.raileurope.com/en/affiliate)
NEXT_PUBLIC_RAILEUROPE_AID=

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_KEY=

# ── Analytics ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Travelpayouts webhook secret ──────────────────────────────────────────────
TP_WEBHOOK_SECRET=

# ── Unsplash ──────────────────────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=
